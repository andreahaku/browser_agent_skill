{
  "name": "browser-agent",
  "version": "0.3.0",
  "description": "Chrome automation CLI for AI agents via the DevTools Protocol",
  "private": true,
  "packageManager": "bun@1.3.7",
  "type": "module",
  "bin": {
    "browser-agent": "dist/browser.js"
  },
  "scripts": {
    "start:chrome": "bash ./scripts/start-chrome.sh",
    "build": "bun build src/browser.js --outfile dist/browser.js --target bun",
    "dev": "bun run src/browser.js",
    "list": "bun run dist/browser.js list",
    "help": "bun run dist/browser.js --help"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {}
}
